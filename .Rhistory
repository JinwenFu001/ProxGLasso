library(SimDesign)
Generate_AR1_pair=function(n,p,rho,cov_AR1=T){
mat1=matrix(0,nrow = p,ncol = p)
for (i in 1:p) {
for (j in 1:p) {
mat1[i,j]=rho^abs(i-j)
}
}
Linv=solve(chol(mat1))
mat2=Linv%*%t(Linv)
mat2=ifelse(abs(mat2)>1e-10,mat2,0)
if(cov_AR1){
cov_mat=mat1
prec_mat=mat2
}else{
cov_mat=mat2
prec_mat=mat1
}
X=rmvnorm(n,sigma=cov_mat)
return(list(covariance=cov_mat,precision=prec_mat,X=X))
}
set.seed(123)
n=20
p=30
a=Generate_AR1_pair(n,p,0.7)
lambda=0.001
start.time <- Sys.time()
a1=BTProx_glasso(cov(a$X),n=n,lambda)
